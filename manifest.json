{
  "manifest_version": 3,
  "name": "ID Finder - Instantly See & Copy Element IDs",
  "version": "1.0.0",
  "description": "Hover over any element to see its ID, click to copy it instantly. Perfect for web developers and testers.",
  "permissions": ["activeTab", "clipboardWrite"],
  "action": {
    "default_title": "Toggle ID Finder (ON/OFF)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "author": "Your Name",
  "homepage_url": "https://your-website.com/id-finder"
}